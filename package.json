{
    "name": "gm_ultimate_ton_smart_contracts",
    "version": "0.0.1",
    "description": "GM Ultimate — a system of TON/Tolk smart contracts: GameManager + swappable Retranslator, RUDA token, games, and TEP reference implementations.",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "bp": "blueprint",
        "start": "blueprint run",
        "build": "blueprint build",
        "test": "NODE_OPTIONS='--max-old-space-size=8192 --expose-gc' jest --verbose --detectOpenHandles",
        "test:single": "NODE_OPTIONS='--max-old-space-size=8192 --expose-gc' jest --verbose --runInBand",
        "abi": "ts-node scripts/deploySystem.ts --offline",
        "verify:hashes": "ts-node scripts/lib/verifyDeploymentHashes.ts",
        "deploy": "ts-node scripts/deploySystem.ts",
        "deploy:testnet": "ts-node scripts/deploySystem.ts --testnet",
        "deploy:mainnet": "ts-node scripts/deploySystem.ts --mainnet",
        "deploy:testnet:hard": "ts-node scripts/deploySystem.ts --testnet --mode hard",
        "deploy:mainnet:hard": "ts-node scripts/deploySystem.ts --mainnet --mode hard",
        "deploy:dry:testnet": "ts-node scripts/deploySystem.ts --testnet --dry-run",
        "deploy:dry:mainnet": "ts-node scripts/deploySystem.ts --mainnet --dry-run",
        "release": "blueprint pack && npm publish --access public",
        "seed": "ts-node scripts/seed.ts",
        "seed:testnet": "ts-node scripts/seed.ts --testnet",
        "seed:dry": "ts-node scripts/seed.ts --testnet --dry-run",
        "seed:race:testnet": "ts-node scripts/seed.ts --testnet --only race",
        "seed:tokens:testnet": "ts-node scripts/seed.ts --testnet --only tokens",
        "seed:ubps:testnet": "ts-node scripts/seedUbps.ts --testnet",
        "seed:ubps:dry": "ts-node scripts/seedUbps.ts --testnet --dry-run",
        "seed:ubps:info": "ts-node scripts/seedUbps.ts --testnet --deployer-info",
        "generate-key": "ts-node scripts/generatePrivateKey.ts",
        "move-ship": "WALLET_VERSION=v4r2 blueprint run moveShip --mnemonic",
        "test-external": "WALLET_VERSION=v4r2 blueprint run testExternalShipStation --mnemonic",
        "check-connection": "ts-node scripts/checkConnection.ts",
        "chainstack": "ts-node scripts/runWithChainstack.ts",
        "get_op": "ts-node scripts/getOpcode.ts"
    },
    "dependencies": {
        "@orbs-network/ton-access": "^2.3.3",
        "@ton/core": "~0.62.0",
        "ton-provider-system": "^0.3.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@tact-lang/compiler": "^1.6.13",
        "@ton-community/func-js": "^0.11.0",
        "@ton/blueprint": "^0.41.0",
        "@ton/crypto": "^3.3.0",
        "@ton/sandbox": "^0.39.0",
        "@ton/test-utils": "^0.12.0",
        "@ton/tolk-js": "^1.2.0",
        "@ton/ton": "^15.4.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^22.19.1",
        "dotenv": "^16.4.5",
        "jest": "^30.2.0",
        "prettier": "^3.7.3",
        "ts-jest": "^29.4.5",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    }
}
